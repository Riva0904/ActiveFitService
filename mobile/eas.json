{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://activefit-api.onrender.com/api/v1",
        "EXPO_PUBLIC_BACKEND_ORIGIN": "https://activefit-api.onrender.com"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://activefit-api.onrender.com/api/v1",
        "EXPO_PUBLIC_BACKEND_ORIGIN": "https://activefit-api.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
