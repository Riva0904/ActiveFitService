generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  GYM_ADMIN
  STAFF
  TRAINER
  MEMBER
}

enum GymStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum SaaSPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SaaSStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum MembershipType {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  CUSTOM
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
  FROZEN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum CheckInMethod {
  QR_CODE
  MANUAL
  BIOMETRIC
}

enum AttendanceCloseReason {
  NORMAL
  AUTO_CHECKOUT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  RAZORPAY
  BANK_TRANSFER
  UPI
}

enum PaymentType {
  MEMBERSHIP
  PT_SESSION
  SUPPLEMENT
  DIET_PLAN
  WORKOUT_PLAN
  OTHER
}

enum NotificationType {
  MEMBERSHIP_EXPIRY
  PAYMENT_DUE
  GENERAL
  OFFER
  SYSTEM
  ATTENDANCE
  LEAVE_REQUEST
  REFERRAL
  WINBACK
}

enum EnquirySource {
  WALK_IN
  PHONE
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum LeaveType {
  SICK
  CASUAL
  EMERGENCY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EnquiryStatus {
  NEW
  CONTACTED
  INTERESTED
  CONVERTED
  NOT_INTERESTED
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  LOGIN_2FA
}

enum ExpenseCategory {
  TRAINER_SALARY
  STAFF_SALARY
  ELECTRICITY
  WATER
  RENT
  EQUIPMENT_MAINTENANCE
  INTERNET
  MARKETING
  OTHER
}

enum PtSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SupplementOrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum ChatType {
  GYM
  SUPPORT
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Gym {
  id                 String     @id @default(uuid())
  name               String
  slug               String     @unique
  email              String     @unique
  phone              String
  address            String
  city               String
  state              String
  pincode            String
  country            String     @default("India")
  timezone           String     @default("Asia/Kolkata")
  logo               String?
  coverImage         String?
  description        String?
  website            String?
  gstin              String?
  amenities          String[]
  openTime           String?
  closeTime          String?
  workingDays        String[]
  maxMembers         Int        @default(100)
  status             GymStatus  @default(PENDING)
  saasPlan           SaaSPlan   @default(STARTER)
  saasStatus         SaaSStatus @default(TRIAL)
  saasExpiresAt      DateTime?
  razorpayAccountId        String?
  renewalRemindersEnabled  Boolean    @default(true)
  // Manual UPI payout details — member payments are collected as a plain UPI
  // QR/intent straight to this VPA (no gateway, no KYC), gym admin confirms
  // receipt manually after checking their own bank/UPI app.
  payoutUpiVpa             String?
  payoutAccountHolder      String?
  payoutBankAccountNumber  String?
  payoutBankIfsc           String?
  payoutPhone              String?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  deletedAt                DateTime?

  users              User[]
  members            Member[]
  trainers           Trainer[]
  staffs             Staff[]
  membershipPlans    MembershipPlan[]
  memberSubscriptions MemberSubscription[]
  attendance         Attendance[]
  occupancySnapshots OccupancySnapshot[]
  payments           Payment[]
  workoutPlans       WorkoutPlan[]
  dietPlans          DietPlan[]
  notifications      Notification[]
  supportTickets     SupportTicket[]
  enquiries          Enquiry[]
  branches           Branch[]
  auditLogs          AuditLog[]
  expenses           Expense[]
  gymSubscriptions   GymSubscription[]
  ptSessions         PtSession[]
  leaveRequests      LeaveRequest[]
  chatConversations  ChatConversation[]
  supplements        Supplement[]
  supplementOrders   SupplementOrder[]
  promoCodes         PromoCode[]
  invoices           Invoice[]
  salaryPayouts      SalaryPayout[]

  @@index([status])
  @@index([saasStatus])
  @@map("gyms")
}

model SaaSSubscriptionPlan {
  id               String     @id @default(uuid())
  name             String     @unique
  plan             SaaSPlan   @unique
  monthlyPrice     Float
  yearlyPrice      Float
  maxMembers       Int
  maxTrainers      Int
  maxStaff         Int
  maxBranches      Int
  features         String[]
  razorpayPlanId   String?
  isActive         Boolean    @default(true)
  commissionPct    Float      @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  gymSubscriptions GymSubscription[]

  @@map("saas_subscription_plans")
}

model GymSubscription {
  id                     String     @id @default(uuid())
  gymId                  String
  planId                 String
  status                 SaaSStatus @default(TRIAL)
  startDate              DateTime
  endDate                DateTime
  amount                 Float
  razorpayOrderId        String?
  razorpayPaymentId      String?
  razorpaySubscriptionId String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  gym                    Gym                  @relation(fields: [gymId], references: [id])
  plan                   SaaSSubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([gymId])
  @@map("gym_subscriptions")
}

model User {
  id                  String    @id @default(uuid())
  gymId               String?
  email               String    @unique
  phone               String?   @unique
  password            String
  firstName           String
  lastName            String
  role                Role
  avatar              String?
  dateOfBirth         DateTime?
  gender              String?
  address             String?
  city                String?
  state               String?
  pincode             String?
  country             String?   @default("India")
  timezone            String?
  emergencyContact    String?
  isActive            Boolean   @default(true)
  isEmailVerified     Boolean   @default(false)
  isPhoneVerified     Boolean   @default(false)
  lastLoginAt         DateTime?
  refreshToken        String?
  // Manual UPI payout — same record-only model as Gym's: gym admin pays salary
  // straight to this VPA via their own banking, then marks the payout Paid.
  payoutUpiVpa        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  gym                 Gym?      @relation(fields: [gymId], references: [id])
  member              Member?
  trainer             Trainer?
  staff               Staff?
  salaryPayouts       SalaryPayout[]
  otpCodes            OtpCode[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  leaveRequests       LeaveRequest[]
  conversations       ChatConversation[] @relation("UserConversations")
  chatMessages        ChatMessage[]      @relation("SentChatMessages")
  attendanceRecords   Attendance[]       @relation("AttendanceUser")
  supplementOrders    SupplementOrder[]
  invoices            Invoice[]          @relation("UserInvoices")

  @@index([gymId])
  @@index([role])
  @@index([email])
  @@map("users")
}

model Member {
  id                  String   @id @default(uuid())
  userId              String   @unique
  gymId               String
  memberCode          String   @unique
  qrToken             String   @unique @default(uuid())
  bloodGroup          String?
  medicalConditions   String?
  fitnessGoals        String?
  profilePhoto        String?
  referralCode        String?  @unique
  referralCredit      Float    @default(0)
  referredById        String?
  joinDate            DateTime @default(now())
  attendanceStreak     Int      @default(0)
  bestAttendanceStreak Int      @default(0)
  lastAttendanceDate   DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  user                User     @relation(fields: [userId], references: [id])
  gym                 Gym      @relation(fields: [gymId], references: [id])
  referredBy          Member?  @relation("MemberReferrals", fields: [referredById], references: [id])
  referrals           Member[] @relation("MemberReferrals")
  memberSubscriptions MemberSubscription[]
  attendance          Attendance[]
  payments            Payment[]
  workoutAssignments  WorkoutAssignment[]
  dietAssignments     DietAssignment[]
  progressLogs        ProgressLog[]
  trainerAssignments  TrainerAssignment[]
  ptSessions          PtSession[]

  @@index([gymId])
  @@index([memberCode])
  @@index([gymId, userId])
  @@index([gymId, deletedAt])
  @@map("members")
}

model Trainer {
  id               String   @id @default(uuid())
  userId           String   @unique
  gymId            String
  employeeId       String?
  specializations  String[]
  certifications   String[]
  experience       Int      @default(0)
  bio              String?
  rating           Float    @default(0)
  hourlyRate       Float?
  isAvailable      Boolean  @default(true)
  joiningDate      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  user             User     @relation(fields: [userId], references: [id])
  gym              Gym      @relation(fields: [gymId], references: [id])
  memberAssignments TrainerAssignment[]
  workoutPlans     WorkoutPlan[]
  dietPlans        DietPlan[]
  ptSessions       PtSession[]

  @@index([gymId])
  @@map("trainers")
}

model Staff {
  id          String   @id @default(uuid())
  userId      String   @unique
  gymId       String
  employeeId  String?
  designation String?
  department  String?
  joiningDate DateTime @default(now())
  salary      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user        User     @relation(fields: [userId], references: [id])
  gym         Gym      @relation(fields: [gymId], references: [id])

  @@index([gymId])
  @@map("staffs")
}

model TrainerAssignment {
  id         String   @id @default(uuid())
  trainerId  String
  memberId   String
  gymId      String
  assignedAt DateTime @default(now())
  isActive   Boolean  @default(true)
  notes      String?

  trainer    Trainer  @relation(fields: [trainerId], references: [id])
  member     Member   @relation(fields: [memberId], references: [id])

  @@unique([trainerId, memberId])
  @@index([gymId])
  @@map("trainer_assignments")
}

model MembershipPlan {
  id             String         @id @default(uuid())
  gymId          String
  name           String
  type           MembershipType
  durationMonths Int
  price          Float
  discount       Float          @default(0)
  features       String[]
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  gym            Gym            @relation(fields: [gymId], references: [id])
  subscriptions  MemberSubscription[]

  @@index([gymId])
  @@map("membership_plans")
}

model MemberSubscription {
  id                 String           @id @default(uuid())
  memberId           String
  gymId              String
  planId             String
  status             MembershipStatus @default(PENDING)
  startDate          DateTime
  endDate            DateTime
  amount             Float
  autoRenew          Boolean          @default(false)
  remindersSent      Int[]            @default([])
  freezeStart        DateTime?
  freezeEnd          DateTime?
  notes              String?
  deletedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  member             Member           @relation(fields: [memberId], references: [id])
  gym                Gym              @relation(fields: [gymId], references: [id])
  plan               MembershipPlan   @relation(fields: [planId], references: [id])
  payments           Payment[]
  invoices           Invoice[]

  @@index([memberId])
  @@index([gymId])
  @@index([status])
  @@index([endDate])
  @@index([gymId, status])
  @@index([gymId, endDate])
  @@map("member_subscriptions")
}

model Attendance {
  id           String           @id @default(uuid())
  userId       String?
  memberId     String?
  gymId        String
  checkInTime  DateTime         @default(now())
  checkOutTime DateTime?
  durationMinutes Int?
  date         DateTime         @default(now()) @db.Date
  status       AttendanceStatus @default(PRESENT)
  method       CheckInMethod    @default(MANUAL)
  closeReason  AttendanceCloseReason @default(NORMAL)
  notes        String?
  markedBy     String?
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User?            @relation("AttendanceUser", fields: [userId], references: [id])
  member       Member?          @relation(fields: [memberId], references: [id])
  gym          Gym              @relation(fields: [gymId], references: [id])

  @@index([userId])
  @@index([memberId])
  @@index([gymId])
  @@index([date])
  @@index([gymId, checkInTime])
  @@index([gymId, memberId])
  @@map("attendance")
}

model OccupancySnapshot {
  id             String   @id @default(uuid())
  gymId          String
  occupancyCount Int
  createdAt      DateTime @default(now())

  gym            Gym      @relation(fields: [gymId], references: [id])

  @@index([gymId])
  @@index([gymId, createdAt])
  @@map("occupancy_snapshots")
}

model Payment {
  id                 String            @id @default(uuid())
  memberId           String
  gymId              String
  subscriptionId     String?
  type               PaymentType
  amount             Float
  status             PaymentStatus     @default(PENDING)
  method             PaymentMethod     @default(CASH)
  razorpayOrderId    String?
  razorpayPaymentId  String?
  memberConfirmedAt  DateTime?
  invoiceUrl         String?
  notes              String?
  promoCodeId        String?
  discountAmount     Float             @default(0)
  platformCommission Float             @default(0)
  dietPlanId         String?
  workoutPlanId      String?
  membershipPlanId   String?
  paidAt             DateTime?
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  member             Member            @relation(fields: [memberId], references: [id])
  gym                Gym               @relation(fields: [gymId], references: [id])
  subscription       MemberSubscription? @relation(fields: [subscriptionId], references: [id])
  promoCode          PromoCode?        @relation(fields: [promoCodeId], references: [id])
  workoutPlan        WorkoutPlan?      @relation(fields: [workoutPlanId], references: [id])
  invoice            Invoice?
  supplementOrder    SupplementOrder?

  @@index([memberId])
  @@index([gymId])
  @@index([status])
  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
  @@index([paidAt])
  @@index([gymId, status])
  @@index([gymId, paidAt])
  @@map("payments")
}

model WorkoutPlan {
  id             String   @id @default(uuid())
  gymId          String
  trainerId      String?
  name           String
  goal           String
  difficulty     String   @default("BEGINNER")
  durationWeeks  Int      @default(4)
  exercises      Json
  isAiGenerated  Boolean  @default(false)
  isTemplate     Boolean  @default(false)
  isPremium      Boolean  @default(false)
  price          Float?
  durationDays   Int?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  gym            Gym      @relation(fields: [gymId], references: [id])
  trainer        Trainer? @relation(fields: [trainerId], references: [id])
  assignments    WorkoutAssignment[]
  payments       Payment[]

  @@index([gymId])
  @@map("workout_plans")
}

model WorkoutAssignment {
  id            String      @id @default(uuid())
  workoutPlanId String
  memberId      String
  gymId         String
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean     @default(true)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
  member        Member      @relation(fields: [memberId], references: [id])

  @@index([gymId])
  @@index([memberId])
  @@map("workout_assignments")
}

model DietPlan {
  id            String   @id @default(uuid())
  gymId         String
  trainerId     String?
  name          String
  goal          String
  totalCalories Int?
  meals         Json
  restrictions  String[]
  isAiGenerated Boolean  @default(false)
  isTemplate    Boolean  @default(false)
  isPremium     Boolean  @default(false)
  price         Float?
  durationDays  Int?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  gym           Gym      @relation(fields: [gymId], references: [id])
  trainer       Trainer? @relation(fields: [trainerId], references: [id])
  assignments   DietAssignment[]

  @@index([gymId])
  @@map("diet_plans")
}

model DietAssignment {
  id         String   @id @default(uuid())
  dietPlanId String
  memberId   String
  gymId      String
  startDate  DateTime
  endDate    DateTime?
  isActive   Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id])
  member     Member   @relation(fields: [memberId], references: [id])

  @@index([gymId])
  @@index([memberId])
  @@map("diet_assignments")
}

model ProgressLog {
  id         String   @id @default(uuid())
  memberId   String
  gymId      String
  weight     Float?
  height     Float?
  bmi        Float?
  bodyFat    Float?
  muscleMass Float?
  chest      Float?
  waist      Float?
  hips       Float?
  arms       Float?
  thighs     Float?
  photos     String[]
  notes      String?
  logDate    DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  member     Member   @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@map("progress_logs")
}

model Notification {
  id          String              @id @default(uuid())
  gymId       String?
  userId      String
  type        NotificationType    @default(GENERAL)
  channel     NotificationChannel @default(IN_APP)
  title       String
  message     String
  isRead      Boolean             @default(false)
  isSent      Boolean             @default(false)
  scheduledAt DateTime?
  sentAt      DateTime?
  metadata    Json?
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user        User                @relation(fields: [userId], references: [id])
  gym         Gym?                @relation(fields: [gymId], references: [id])

  @@index([userId])
  @@index([gymId])
  @@index([isRead])
  @@map("notifications")
}

model SupportTicket {
  id          String         @id @default(uuid())
  gymId       String
  raisedBy    String
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  attachments String[]
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  gym         Gym            @relation(fields: [gymId], references: [id])

  @@index([gymId])
  @@index([status])
  @@map("support_tickets")
}

model Enquiry {
  id                  String        @id @default(uuid())
  gymId               String
  name                String
  phone               String
  email               String?
  source              EnquirySource?
  interest            String?
  status              EnquiryStatus @default(NEW)
  followUpDate        DateTime?
  notes               String?
  assignedTo          String?
  convertedMemberId   String?
  deletedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  gym                 Gym           @relation(fields: [gymId], references: [id])

  @@index([gymId])
  @@index([status])
  @@map("enquiries")
}

model PromoCode {
  id            String       @id @default(uuid())
  gymId         String
  code          String
  discountType  DiscountType
  discountValue Float
  maxUses       Int?
  usedCount     Int          @default(0)
  validFrom     DateTime
  validTo       DateTime
  isActive      Boolean      @default(true)
  description   String?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  gym           Gym          @relation(fields: [gymId], references: [id])
  payments      Payment[]

  @@unique([gymId, code])
  @@index([gymId])
  @@index([code])
  @@map("promo_codes")
}

model Branch {
  id          String   @id @default(uuid())
  gymId       String
  name        String
  address     String
  city        String
  state       String
  pincode     String
  phone       String?
  managerName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  gym         Gym      @relation(fields: [gymId], references: [id])

  @@index([gymId])
  @@map("branches")
}

model Expense {
  id          String          @id @default(uuid())
  gymId       String
  title       String
  amount      Float
  category    ExpenseCategory
  description String?
  date        DateTime
  month       Int
  year        Int
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  gym         Gym             @relation(fields: [gymId], references: [id])

  @@index([gymId])
  @@map("expenses")
}

model AuditLog {
  id         String   @id @default(uuid())
  gymId      String?
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  gym        Gym?     @relation(fields: [gymId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([gymId])
  @@index([userId])
  @@index([entity])
  @@index([gymId, entity, action, entityId])
  @@map("audit_logs")
}

model OtpCode {
  id        String     @id @default(uuid())
  userId    String?
  email     String?
  phone     String?
  code      String
  purpose   OtpPurpose
  isUsed    Boolean    @default(false)
  expiresAt DateTime
  attempts  Int        @default(0)
  deletedAt DateTime?
  createdAt DateTime   @default(now())

  user      User?      @relation(fields: [userId], references: [id])

  @@index([email, purpose])
  @@index([phone, purpose])
  @@index([userId])
  @@map("otp_codes")
}

model PtSession {
  id          String          @id @default(uuid())
  gymId       String
  trainerId   String
  memberId    String
  title       String?
  scheduledAt DateTime
  duration    Int             @default(60)
  status      PtSessionStatus @default(SCHEDULED)
  notes       String?
  feedback    String?
  rating      Int?
  completedAt DateTime?
  price       Float?
  paymentId   String?
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  gym         Gym             @relation(fields: [gymId], references: [id])
  trainer     Trainer         @relation(fields: [trainerId], references: [id])
  member      Member          @relation(fields: [memberId], references: [id])

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
  @@index([status])
  @@map("pt_sessions")
}

model ChatConversation {
  id            String        @id @default(uuid())
  gymId         String
  userId        String
  type          ChatType      @default(GYM)
  lastMessage   String?
  lastMessageAt DateTime      @default(now())
  unreadAdmin   Int           @default(0)
  unreadUser    Int           @default(0)
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  gym           Gym           @relation(fields: [gymId], references: [id])
  user          User          @relation("UserConversations", fields: [userId], references: [id])
  messages      ChatMessage[]

  @@unique([gymId, userId, type])
  @@index([gymId])
  @@index([type])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  senderId       String
  content        String           @default("")
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  isRead         Boolean          @default(false)
  isDeleted      Boolean          @default(false)
  reactions      Json             @default("[]")
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("SentChatMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("chat_messages")
}

model LeaveRequest {
  id          String      @id @default(uuid())
  gymId       String
  userId      String
  leaveType   LeaveType
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      LeaveStatus @default(PENDING)
  adminNote   String?
  reviewedBy  String?
  reviewedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  gym         Gym         @relation(fields: [gymId], references: [id])

  @@index([gymId])
  @@index([userId])
  @@index([status])
  @@map("leave_requests")
}

model Supplement {
  id            String    @id @default(uuid())
  gymId         String
  name          String
  category      String
  brand         String?
  description   String?
  price         Float
  discountPrice Float?
  stock         Int       @default(0)
  weight        String?
  images        String[]
  isFeatured    Boolean   @default(false)
  isActive      Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  gym           Gym                   @relation(fields: [gymId], references: [id])
  orderItems    SupplementOrderItem[]

  @@index([gymId])
  @@index([category])
  @@map("supplements")
}

model SupplementOrder {
  id          String                @id @default(uuid())
  gymId       String
  userId      String
  paymentId   String?               @unique
  orderNumber String                @unique
  totalAmount Float
  status      SupplementOrderStatus @default(PENDING)
  deletedAt   DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  gym         Gym                   @relation(fields: [gymId], references: [id])
  user        User                  @relation(fields: [userId], references: [id])
  payment     Payment?              @relation(fields: [paymentId], references: [id])
  items       SupplementOrderItem[]

  @@index([gymId])
  @@index([userId])
  @@index([status])
  @@map("supplement_orders")
}

model SupplementOrderItem {
  id           String     @id @default(uuid())
  orderId      String
  supplementId String
  quantity     Int
  unitPrice    Float
  totalPrice   Float
  createdAt    DateTime   @default(now())

  order        SupplementOrder @relation(fields: [orderId], references: [id])
  supplement   Supplement      @relation(fields: [supplementId], references: [id])

  @@index([orderId])
  @@index([supplementId])
  @@map("supplement_order_items")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  gymId         String
  userId        String
  membershipId  String?
  paymentId     String?       @unique
  amount        Float
  tax           Float         @default(0)
  discount      Float         @default(0)
  totalAmount   Float
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  pdfUrl        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  gym           Gym                 @relation(fields: [gymId], references: [id])
  user          User                @relation("UserInvoices", fields: [userId], references: [id])
  membership    MemberSubscription? @relation(fields: [membershipId], references: [id])
  payment       Payment?            @relation(fields: [paymentId], references: [id])

  @@index([gymId])
  @@index([userId])
  @@index([gymId, status])
  @@map("invoices")
}

model RevokedToken {
  jti        String   @id
  expiresAt  DateTime
  revokedAt  DateTime @default(now())

  @@index([expiresAt])
  @@map("revoked_tokens")
}

enum PayoutStatus {
  PENDING
  PAID
}

// Record-only salary payout: gym admin transfers money to the trainer/staff's
// own UPI/bank manually (outside this app), then marks the record Paid here
// purely for audit history. No gateway, no automated bank movement.
model SalaryPayout {
  id          String       @id @default(uuid())
  gymId       String
  userId      String
  amount      Float
  periodLabel String
  status      PayoutStatus @default(PENDING)
  notes       String?
  paidAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  gym         Gym          @relation(fields: [gymId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@index([gymId])
  @@index([userId])
  @@index([gymId, status])
  @@map("salary_payouts")
}
